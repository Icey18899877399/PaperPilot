APP_NAME=多Agent论文智能阅读系统
APP_ENV=development
BACKEND_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173
MAX_PDF_SIZE_MB=50

# DeepSeek test configuration. Keep the real key only in .env.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_THINKING=false

# Optional generic OpenAI-compatible model service.
# DeepSeek settings take priority when DEEPSEEK_API_KEY is configured.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=

# MinerU service. Leave blank to use PyPDF text extraction for local development.
# Use port 8001 so it does not conflict with this project's backend on port 8000.
MINERU_API_URL=
MINERU_API_TOKEN=
MINERU_BACKEND=pipeline
MINERU_LANGUAGE=ch
MINERU_TIMEOUT_SECONDS=3600

# Optional OpenAI-compatible embedding service for US-04 vector retrieval.
# Leave blank to use the built-in local TF-IDF vector index (no dependency).
EMBEDDING_API_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=

# Optional OpenAI-compatible vision model for image/chart chunk explanation (US-07).
# Leave blank to explain image/chart from caption+context text only.
VISION_API_URL=
VISION_API_KEY=
VISION_MODEL=

# Optional expansion-learning providers. OpenAlex and Crossref work without
# credentials; providing the optional values improves identification/rate limits.
OPENALEX_API_KEY=
CROSSREF_MAILTO=
LEARNING_SEARCH_TIMEOUT_SECONDS=20
